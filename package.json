{
  "name": "orbit",
  "version": "0.1.0",
  "private": true,
  "description": "Keep track of your recurring maintenance tasks",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "concurrently -k -n cljs,css \"shadow-cljs watch app\" \"tailwindcss -i src/css/main.css -o public/css/main.css --watch\"",
    "build": "shadow-cljs release app && tailwindcss -i src/css/main.css -o public/css/main.css --minify",
    "test": "shadow-cljs compile test && node out/node-tests.js",
    "lint": "clj-kondo --lint src test",
    "fmt": "clojure -M:cljfmt check",
    "fmt:fix": "clojure -M:cljfmt fix",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "shadow-cljs": "^3.4.5",
    "tailwindcss": "^4.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@parcel/watcher"]
  },
  "lint-staged": {
    "*.cljs": [
      "clj-kondo --lint",
      "clojure -M:cljfmt fix",
      "bash -c 'pnpm test'"
    ]
  }
}
